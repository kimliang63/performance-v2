// ═══ Render ═══
function render() {
  const root = document.getElementById('pageRoot');
  if (subPage === 'scheme') root.innerHTML = renderSchemePage();
  else if (subPage === 'oplog') root.innerHTML = renderOpLogPage();
  else if (subPage === 'detail') root.innerHTML = renderDetailPage();
  else root.innerHTML = renderMainPage();
}

function renderMainPage() {
  const hasSelection = selectedRows.size > 0;
  const activeStage = STAGES.find(s => s.status === 'active') || STAGES[0];
  const exceptionCount = tableData.filter(r => r.exception !== '-').length;
  return `
    <!-- Activity Header -->
    <div class="act-hd">
      <div class="act-hd-l">
        <button class="back-btn" onclick="history.back()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>
        <div class="act-hd-info">
          <div class="act-title-row"><span class="act-title">2025年上半年绩效考核活动</span><span class="status-tag green">进行中</span></div>
          <div class="act-meta"><span>考核周期：2025-01-01 ~ 2025-06-30</span><div class="sep"></div><span>考核方式：360度考核</span><div class="sep"></div><span>评分规则：5分制</span></div>
        </div>
      </div>
      <div class="act-hd-r">
        <button class="act-link-btn" onclick="openSubPage('scheme')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>方案详情</button>
        <button class="act-link-btn" onclick="openSubPage('oplog')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="12 8 12 12 14 14"/><circle cx="12" cy="12" r="10"/></svg>操作记录</button>
      </div>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
      <div class="filter-row">
        <div class="filter-group"><span class="filter-label">当前节点</span><select class="filter-select" id="fNode"><option value="">全部</option><option>目标制定</option><option>绩效考核</option><option>结果审定</option><option>结果确认</option><option>绩效面谈</option></select></div>
        <div class="filter-group"><span class="filter-label">异常状态</span><select class="filter-select" id="fException"><option value="">全部</option><option>超时</option><option>逾期</option><option>缺少操作</option><option>不确认</option></select></div>
        <div class="filter-group"><span class="filter-label">考核组</span><select class="filter-select" id="fGroup"><option value="">全部</option><option>管理层组</option><option>员工组</option><option>默认组</option></select></div>
        <div class="filter-group"><span class="filter-label">部门</span><select class="filter-select" id="fDept"><option value="">全部</option><option>技术部</option><option>产品部</option><option>设计部</option><option>人力资源部</option><option>市场部</option><option>运营部</option></select></div>
        <input type="text" class="filter-search" placeholder="搜索姓名、工号、部门、处理人" id="fSearch" />
        <button class="filter-reset" onclick="resetFilters()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>重置</button>
      </div>
    </div>

    <!-- Table -->
    <div class="table-wrap">
      <table>
        <thead><tr>
          <th class="col-check"><input type="checkbox" class="table-checkbox" id="selectAll" onchange="toggleSelectAll()" /></th>
          <th class="col-name">姓名</th><th>工号</th><th>部门</th><th>当前节点</th><th>当前处理人</th><th>初评等级</th><th>审定等级</th><th>确认状态</th><th>异常状态</th><th class="col-reason">异常原因</th><th>更新时间</th><th class="col-ops">操作</th>
        </tr></thead>
        <tbody id="tableBody"></tbody>
      </table>
    </div>

    <!-- Bottom Bar -->
    <div class="bottom-bar">
      <div class="bottom-left">
        <div class="selected-info">
          <input type="checkbox" class="table-checkbox" id="bottomSelectAll" onchange="toggleSelectAll()" />
          <span>已选 <span class="count" id="selectedCount">0</span> 人</span>
        </div>
        <button class="clear-btn" onclick="clearSelection()">清空选择</button>
      </div>
      <div class="bottom-right">
        <span class="total-text">共 128 条</span>
        <div class="pagination">
          <button class="pg-btn disabled" onclick="goPage('prev')">&lt;</button>
          <button class="pg-btn active" onclick="goPage(1)">1</button>
          <button class="pg-btn" onclick="goPage(2)">2</button>
          <button class="pg-btn" onclick="goPage(3)">3</button>
          <button class="pg-btn" onclick="goPage(4)">4</button>
          <button class="pg-btn" onclick="goPage(5)">5</button>
          <span class="pg-ellipsis">...</span>
          <button class="pg-btn" onclick="goPage(13)">13</button>
          <button class="pg-btn" onclick="goPage('next')">&gt;</button>
        </div>
        <select class="page-size-select" onchange="showToast('每页 '+this.value+' 条')"><option value="10">10 条/页</option><option value="20">20 条/页</option><option value="50">50 条/页</option></select>
      </div>
    </div>`;
}

// ═══ Flow Operations ═══
function getFlowOps(row) {
  const n = row.nodeName, s = row.status;
  if (n === '目标制定' && s === '已完成') return [{label:'查看'}];
  if (n === '目标制定' && s === '进行中') return [{label:'查看'},{label:'催办'},{label:'转交'},{label:'暂停'}];
  if (n === '绩效考核' && s === '进行中') return [{label:'查看'},{label:'催办'},{label:'转交'},{label:'暂停'}];
  if (n === '绩效考核' && s === '待处理') return [{label:'查看'},{label:'催办'},{label:'转交'},{label:'暂停'}];
  if (n === '结果审定' && s === '超时') return [{label:'查看'},{label:'催办'},{label:'转交'},{label:'继续'},{label:'终止',danger:true}];
  if (n === '结果确认' && s === '待处理') return [{label:'查看'},{label:'催办'},{label:'暂停'}];
  if (n === '绩效面谈' && s === '未开始') return [{label:'查看'}];
  return [{label:'查看'}];
}

function renderTable() {
  const tbody = document.getElementById('tableBody');
  if (!tbody) return;
  tbody.innerHTML = tableData.map((row, i) => {
    const checked = selectedRows.has(i) ? 'checked' : '';
    const ops = getFlowOps(row);
    const isExpanded = expandedOps.has(i);
    const defaultOp = ops[0];
    const extraCount = ops.length - 1;
    const confirmCls = row.confirmStatus==='不确认'?'ex-orange':row.confirmStatus==='已确认'?'ex-green':'';
    const confirmStyle = row.confirmStatus==='不确认'?'color:var(--ac700);background:var(--ac50)':row.confirmStatus==='已确认'?'color:var(--em700);background:var(--em50)':'color:var(--c5)';
    return `<tr>
      <td class="col-check"><input type="checkbox" class="table-checkbox" ${checked} onchange="toggleRow(${i})" /></td>
      <td class="col-name"><a class="name-link" href="javascript:void(0)">${row.name}</a></td>
      <td style="font:400 12px/1 var(--f);color:var(--c6)">${row.emp}</td>
      <td>${row.dept}</td>
      <td><div class="node-badge"><span class="node-num">${row.node}</span><span class="node-name">${row.nodeName}</span></div></td>
      <td>${row.handler}</td>
      <td><span class="grade${row.grade==='-'?' dash':''}">${row.grade}</span></td>
      <td><span class="grade${row.approveGrade==='-'?' dash':''}">${row.approveGrade}</span></td>
      <td>${row.confirmStatus==='-'?'<span class="ex-dash">-</span>':`<span class="ex-tag" style="${confirmStyle}">${row.confirmStatus}</span>`}</td>
      <td>${row.exception==='-'?'<span class="ex-dash">-</span>':`<span class="ex-tag ${row.exceptionCls}">${row.exception}</span>`}</td>
      <td class="col-reason" title="${row.exceptionReason}">${row.exceptionReason}</td>
      <td style="font:400 12px/1 var(--f);color:var(--c6)">${row.updateTime}</td>
      <td class="col-ops ops-cell">
        <div class="ops-default">
          <a href="javascript:void(0)" onclick="viewDetail(${i})">${defaultOp.label}</a>
          ${extraCount>0?`<button class="ops-expand-btn${isExpanded?' open':''}" onclick="toggleOps(${i})">更多${ICO.chevDown}</button>`:''}
        </div>
        ${extraCount>0?`<div class="ops-panel${isExpanded?' show':''}" id="opsPanel${i}">
          ${ops.slice(1).map(op => op.danger
            ?`<div class="ops-panel-divider"></div><div class="ops-panel-item danger" onclick="showToast('${op.label} ${row.name}')">${op.label}</div>`
            :`<div class="ops-panel-item" onclick="showToast('${op.label} ${row.name}')">${op.label}</div>`
          ).join('')}
        </div>`:''}
      </td>
    </tr>`;
  }).join('');
}

// ═══ Employee Detail ═══
function viewDetail(idx) { detailIdx = idx; subPage = 'detail'; render(); }

const NODE_DETAIL_DATA = [
  [{node:'考核人填写',handler:'李四（技术部经理）',status:'进行中',time:'-',submitAction:'提交',form:'绩效考核表'},
   {node:'二级考核人',handler:'王五（产品部经理）',status:'未开始',time:'-',submitAction:'-',form:'绩效考核表'},
   {node:'HRBP 确认',handler:'赵六（HRBP）',status:'未开始',time:'-',submitAction:'-',form:'HRBP确认表'},
   {node:'校准/审定',handler:'孙七（审定委员会成员）',status:'未开始',time:'-',submitAction:'-',form:'审定意见表'},
   {node:'SSC 审核',handler:'周八（SSC绩效专员）',status:'未开始',time:'-',submitAction:'-',form:'SSC审核表'}],
];

function renderDetailPage() {
  const row = tableData[detailIdx];
  const d = DETAIL_DATA[detailIdx];
  if (!row || !d) return '<div style="padding:24px;color:var(--c5)">暂无详情</div>';
  const nodes = NODE_DETAIL_DATA[0];
  const statusCls = {'进行中':'st-blue','已提交':'st-green','未开始':'st-gray','已挂起':'st-orange','已超时':'st-red'};
  const statusStyle = {'进行中':'color:var(--pr);background:var(--pr50)','已提交':'color:var(--em700);background:var(--em50)','未开始':'color:var(--c5);background:var(--c2)','已挂起':'color:var(--ac700);background:var(--ac50)','已超时':'color:var(--ro700);background:var(--ro50)'};
  return `<div class="detail-card">
    <!-- Breadcrumb -->
    <div class="detail-breadcrumb">
      <button class="back" onclick="if(subPage){subPage=null;detailIdx=null;render()}else{window.location.href='perf-activity.html'}">← 返回</button>
      <span class="sep">|</span>
      <span>活动详情</span>
      <span class="sep">/</span>
      <span>员工详情</span>
    </div>

    <!-- Title -->
    <div class="detail-title-row">
      <div class="detail-title-l">
        <div class="detail-title-name">${d.name}（${d.emp}）<span class="status-tag green">${row.status}</span></div>
        <div class="detail-title-meta">${d.dept}<span class="sep">/</span>${d.position}<span class="sep">/</span>员工组</div>
      </div>
      <div class="detail-title-r">
        <button class="btn btn-s" onclick="showToast('已发送催办提醒')">催办</button>
        <button class="btn btn-s" onclick="showTransferDlg()">转交</button>
      </div>
    </div>

    <!-- Flow Progress -->
    <div class="detail-flow">
      ${d.stages.map((s, i) => {
        const dotCls = s.status==='done'?'done':s.status==='active'?'active':'pending';
        const dotContent = s.status==='done'?'✓':(i+1);
        const statusLabel = s.status==='done'?'已提交':s.status==='active'?'进行中':'未开始';
        const dateText = s.status==='done'?'2026-01-0'+(i+1):s.status==='active'?'当前节点':'';
        return `<div class="detail-flow-stage">
          <div class="detail-flow-dot ${dotCls}">${dotContent}</div>
          <div class="detail-flow-name">${s.name}</div>
          <span class="detail-flow-status ${dotCls}">${statusLabel}</span>
          ${dateText?`<div class="detail-flow-date">${dateText}</div>`:''}
        </div>`;
      }).join('')}
    </div>

    <!-- Stage Tab -->
    <div class="detail-stage-tab">绩效考核</div>

    <!-- Node Detail Table -->
    <div class="detail-sec-title">节点处理明细</div>
    <table class="detail-node-tbl">
      <thead><tr><th>节点</th><th>处理人</th><th>处理状态</th><th>提交时间</th><th>提交原因</th><th>相关表单</th></tr></thead>
      <tbody>
        ${nodes.map(n => `<tr>
          <td style="font-weight:500">${n.node}</td>
          <td>${n.handler}</td>
          <td><span class="ex-tag" style="${statusStyle[n.status]||''}">${n.status}</span></td>
          <td>${n.time}</td>
          <td>${n.submitAction==='-'?'<span class="dash">-</span>':`<span class="ex-tag" style="color:var(--c7);background:var(--c1)">${n.submitAction}</span>`}</td>
          <td><a class="link" onclick="showToast('查看${n.form}')">${n.form}</a></td>
        </tr>`).join('')}
      </tbody>
    </table>

  </div>`;
}

// ═══ Scheme Detail ═══
function renderSchemePage() {
  const s = SCHEME;
  return `<div>
    <div class="sub-page-hd"><button class="back" onclick="closeSubPage()">← 返回</button><span class="title">方案详情</span></div>
    <div class="scheme-section"><div class="scheme-section-hd"><span class="scheme-section-title">基本信息</span></div><div class="scheme-section-bd"><div class="scheme-grid">
      <div class="scheme-item"><span class="label">方案名称</span><span class="value">${s.name}</span></div>
      <div class="scheme-item"><span class="label">方案编号</span><span class="value" style="font-family:monospace">${s.code}</span></div>
      <div class="scheme-item"><span class="label">方案版本</span><span class="value">${s.version}</span></div>
      <div class="scheme-item"><span class="label">是否启用</span><span class="value" style="color:var(--em)">${s.enabled?'已启用':'已停用'}</span></div>
      <div class="scheme-item" style="grid-column:1/-1"><span class="label">描述</span><span class="value">${s.desc}</span></div>
    </div></div></div>
    <div class="scheme-section"><div class="scheme-section-hd"><span class="scheme-section-title">绩效等级</span></div><div class="scheme-section-bd">
      <div class="scheme-item" style="margin-bottom:12px"><span class="label">等级规则</span><span class="value">${s.gradeRule}</span></div>
      <div class="scheme-tags">${s.grades.map(g=>`<span class="scheme-tag ${g.color}">${g.name} <strong>${g.code}</strong> ${g.range}</span>`).join('')}</div>
    </div></div>
    <div class="scheme-section"><div class="scheme-section-hd"><span class="scheme-section-title">考核组</span></div><div class="scheme-section-bd"><div class="scheme-group-list">
      ${s.groups.map(g=>`<div class="scheme-group-item"><div class="scheme-group-name">${g.name} ${g.isDefault?'<span class="badge">默认</span>':''}</div><div class="scheme-group-rules">适用规则：${g.rules}</div><div class="scheme-group-rules">排除人员：${g.excluded}</div></div>`).join('')}
    </div></div></div>
    <div class="scheme-section"><div class="scheme-section-hd"><span class="scheme-section-title">考核环节</span></div><div class="scheme-section-bd"><div class="scheme-stage-list">
      ${s.stages.map(st=>`<div class="scheme-stage-item"><div><div class="scheme-stage-name">${st.name}</div><div class="scheme-stage-desc">${st.desc} · ${st.flow}</div></div><span class="scheme-stage-tag ${st.enabled?'on':'off'}">${st.enabled?'已启用':'未启用'}</span></div>`).join('')}
    </div></div></div>
    <div class="scheme-section"><div class="scheme-section-hd"><span class="scheme-section-title">强制分布</span></div><div class="scheme-section-bd">
      <div class="scheme-item"><span class="label">强制分布规则</span><span class="value">${s.forcedDist}</span></div>
    </div></div>
  </div>`;
}

// ═══ Op Log ═══
function renderOpLogPage() {
  return `<div>
    <div class="sub-page-hd"><button class="back" onclick="closeSubPage()">← 返回</button><span class="title">操作记录</span></div>
    <div style="background:var(--sf);border:1px solid var(--c3);border-radius:var(--r2);box-shadow:var(--shadow);overflow:hidden">
      <table class="oplog-table"><thead><tr><th>时间</th><th>操作人</th><th>操作类型</th><th>操作对象</th><th>详情</th></tr></thead><tbody>
        ${OP_LOGS.map(l=>`<tr><td class="oplog-time">${l.time}</td><td>${l.operator}</td><td><span class="oplog-type ${l.typeCls}">${l.type}</span></td><td>${l.target}</td><td>${l.detail}</td></tr>`).join('')}
      </tbody></table>
    </div>
    <div style="padding:12px 0;font:400 13px/1 var(--f);color:var(--c6)">共 ${OP_LOGS.length} 条操作记录</div>
  </div>`;
}

// ═══ Interactions ═══
function openSubPage(p){subPage=p;detailIdx=null;render();}
function closeSubPage(){subPage=null;render();}
function toggleRow(idx){if(selectedRows.has(idx))selectedRows.delete(idx);else selectedRows.add(idx);updateSelectionUI();}
function toggleSelectAll(){if(selectedRows.size===tableData.length)selectedRows.clear();else tableData.forEach((_,i)=>selectedRows.add(i));renderTable();updateSelectionUI();}
function clearSelection(){selectedRows.clear();renderTable();updateSelectionUI();}
function updateSelectionUI(){const c=selectedRows.size;document.getElementById('selectedCount').textContent=c;const sa=document.getElementById('selectAll');const bsa=document.getElementById('bottomSelectAll');if(sa)sa.checked=c===tableData.length&&tableData.length>0;if(bsa)bsa.checked=sa?.checked;}
function toggleOps(idx){if(expandedOps.has(idx))expandedOps.delete(idx);else expandedOps.add(idx);renderTable();document.querySelectorAll('.ops-panel').forEach(p=>{const id=parseInt(p.id.replace('opsPanel',''));if(id!==idx)p.classList.remove('show');});}
function resetFilters(){['fNode','fException','fGroup','fDept','fSearch'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});showToast('筛选已重置');}
function toggleDropdown(id){const dd=document.getElementById(id);const wasOpen=dd.classList.contains('show');document.querySelectorAll('.dropdown-menu').forEach(d=>d.classList.remove('show'));if(!wasOpen)dd.classList.add('show');}
function goPage(p){if(p==='prev')p=Math.max(1,currentPage-1);else if(p==='next')p=Math.min(13,currentPage+1);currentPage=p;document.querySelectorAll('.pagination .pg-btn').forEach(btn=>{const t=btn.textContent.trim();btn.classList.remove('active','disabled');if(t===String(currentPage))btn.classList.add('active');if((t==='<'&&currentPage===1)||(t==='>'&&currentPage===13))btn.classList.add('disabled');});}
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(t._timer);t._timer=setTimeout(()=>t.classList.remove('show'),2000);}
function showTransferDlg(){
  const ov=document.createElement('div');ov.className='cfm-ov';ov.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:2100;display:flex;align-items:center;justify-content:center';
  ov.innerHTML=`<div style="background:var(--sf);border-radius:var(--r3);box-shadow:0 20px 60px rgba(0,0,0,.2);width:400px;padding:24px">
    <div style="font:600 15px/1.3 var(--f);color:var(--c9);margin-bottom:16px">转交流程</div>
    <div style="margin-bottom:20px"><input style="width:100%;height:36px;padding:0 12px;border:1px solid var(--c3);border-radius:var(--r1);font:400 13px/1 var(--f);color:var(--c7);outline:none" placeholder="请输入转交人姓名" /></div>
    <div style="display:flex;justify-content:flex-end;gap:8px">
      <button class="btn btn-s" onclick="this.closest('.cfm-ov').remove()">取消</button>
      <button class="btn btn-p" onclick="showToast('已转交');this.closest('.cfm-ov').remove()">确认转交</button>
    </div>
  </div>`;
  ov.addEventListener('click',e=>{if(e.target===ov)ov.remove();});
  document.body.appendChild(ov);
}
document.addEventListener('click',function(e){if(!e.target.closest('.dropdown-wrap'))document.querySelectorAll('.dropdown-menu').forEach(d=>d.classList.remove('show'));if(!e.target.closest('.ops-cell')){document.querySelectorAll('.ops-panel').forEach(p=>p.classList.remove('show'));expandedOps.clear();}});

// ═══ Init ═══
GHR_NAV.init('perf', '活动详情');
render();
renderTable();
</script>
</body>
</html>
