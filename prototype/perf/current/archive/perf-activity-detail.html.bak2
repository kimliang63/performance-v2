<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>绩效考核活动详情 - HR ONE</title>
<style>
:root{
  --pr:#1677FF;--pr50:#E6F4FF;--pr700:#0958D9;
  --em:#16A34A;--em50:#DCFCE7;--em700:#15803D;
  --ac:#EA580C;--ac50:#FFF7ED;--ac700:#C2410C;
  --ro:#DC2626;--ro50:#FEF2F2;--ro700:#B91C1C;
  --vi:#7C3AED;--vi50:#F5F3FF;
  --c9:#0F172A;--c8:#1E293B;--c7:#334155;--c6:#64748B;--c5:#94A3B8;--c4:#CBD5E1;--c3:#E5E7EB;--c2:#F1F5F9;--c1:#F8FAFC;
  --sf:#FFF;--bg:#F8FAFC;--dv:#F1F5F9;
  --shadow:0 1px 3px rgba(0,0,0,.05),0 1px 2px rgba(0,0,0,.03);
  --r1:6px;--r2:8px;--r3:10px;
  --f:-apple-system,BlinkMacSystemFont,"Segoe UI","PingFang SC","Microsoft YaHei",sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:var(--f);background:var(--bg);color:var(--c9);-webkit-font-smoothing:antialiased;line-height:1.5}
::-webkit-scrollbar{width:5px;height:5px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--c4);border-radius:3px}


/* ═══ Buttons ═══ */
.btn{display:inline-flex;align-items:center;gap:6px;padding:0 14px;height:32px;border-radius:var(--r1);font:500 13px/1 var(--f);cursor:pointer;transition:all .12s;border:none;font-family:var(--f);white-space:nowrap}
.btn svg{width:14px;height:14px}
.btn-p{background:var(--pr);color:#FFF}.btn-p:hover{background:var(--pr700)}
.btn-s{background:var(--sf);color:var(--c7);border:1px solid var(--c3)}.btn-s:hover{border-color:var(--pr);color:var(--pr)}
.btn-d{background:var(--ro50);color:var(--ro);border:1px solid #FECACA}.btn-d:hover{background:#FEE2E2;border-color:var(--ro)}

/* ═══ Dropdown ═══ */
.dropdown-wrap{position:relative}
.dropdown-menu{position:absolute;top:calc(100% + 4px);right:0;background:var(--sf);border:1px solid var(--c3);border-radius:var(--r1);box-shadow:0 6px 16px rgba(0,0,0,.08);min-width:160px;z-index:100;padding:4px 0;display:none}
.dropdown-menu.show{display:block}
.dropdown-item{padding:8px 14px;font:400 13px/1 var(--f);color:var(--c7);cursor:pointer;transition:background .1s;display:flex;align-items:center;gap:6px}
.dropdown-item:hover{background:var(--c1)}
.dropdown-item.danger{color:var(--ro)}
.dropdown-divider{height:1px;background:var(--dv);margin:4px 0}

/* ═══ Activity Header ═══ */
.act-hd{padding:16px 0;border-bottom:1px solid var(--dv);margin-bottom:16px;display:flex;align-items:flex-start;justify-content:space-between}
.act-hd-l{display:flex;align-items:flex-start;gap:12px}
.back-btn{width:32px;height:32px;border-radius:var(--r1);border:1px solid var(--c3);background:var(--sf);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--c6);transition:all .15s;flex-shrink:0;margin-top:2px}
.back-btn:hover{border-color:var(--pr);color:var(--pr)}
.back-btn svg{width:16px;height:16px}
.act-hd-info{display:flex;flex-direction:column;gap:6px}
.act-title-row{display:flex;align-items:center;gap:10px}
.act-title{font:700 20px/1.3 var(--f);color:var(--c9)}
.status-tag{display:inline-flex;align-items:center;font:500 12px/1 var(--f);padding:3px 10px;border-radius:4px}
.status-tag.green{color:var(--em700);background:var(--em50)}
.act-meta{display:flex;align-items:center;gap:8px;font:400 13px/1 var(--f);color:var(--c6)}
.act-meta .sep{width:1px;height:14px;background:var(--c3)}
.act-hd-r{display:flex;align-items:center;gap:12px;flex-shrink:0}
.act-link-btn{display:flex;align-items:center;gap:5px;font:500 13px/1 var(--f);color:var(--c6);cursor:pointer;background:none;border:none;padding:4px;border-radius:4px;transition:color .15s}
.act-link-btn:hover{color:var(--pr)}
.act-link-btn svg{width:16px;height:16px}


/* ═══ Filter Bar ═══ */
.filter-bar{padding:12px 0}
.filter-row{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.filter-group{display:flex;align-items:center;gap:6px}
.filter-label{font:500 13px/1 var(--f);color:var(--c6);white-space:nowrap}
.filter-select{height:32px;padding:0 28px 0 10px;border:1px solid var(--c3);border-radius:var(--r1);font:400 13px/1 var(--f);color:var(--c7);background:var(--sf) url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%2394A3B8' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E") no-repeat right 8px center;appearance:none;cursor:pointer;outline:none;font-family:var(--f);min-width:100px}
.filter-select:focus{border-color:var(--pr)}
.filter-search{height:32px;border:1px solid var(--c3);border-radius:var(--r1);padding:0 10px 0 32px;font:400 13px/1 var(--f);color:var(--c7);outline:none;width:220px;background:var(--sf) url("data:image/svg+xml,%3Csvg width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='%2394A3B8' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='11' cy='11' r='8'/%3E%3Cline x1='21' y1='21' x2='16.65' y2='16.65'/%3E%3C/svg%3E") no-repeat 10px center;font-family:var(--f)}
.filter-search:focus{border-color:var(--pr)}
.filter-search::placeholder{color:var(--c5)}
.filter-reset{display:flex;align-items:center;gap:4px;font:500 13px/1 var(--f);color:var(--c6);cursor:pointer;background:none;border:none;padding:4px 8px;border-radius:4px;transition:color .15s;font-family:var(--f)}
.filter-reset:hover{color:var(--pr)}
.filter-reset svg{width:14px;height:14px}

/* ═══ Table ═══ */
.table-wrap{background:var(--sf);border:1px solid var(--c3);border-radius:var(--r2);box-shadow:var(--shadow);overflow-x:auto;position:relative}
table{border-collapse:collapse;table-layout:auto}
thead th{background:var(--c1);font:600 12px/1 var(--f);color:var(--c6);text-align:left;padding:12px 14px;border-bottom:1px solid var(--dv);white-space:nowrap;position:sticky;top:0;z-index:2}
tbody td{padding:13px 14px;border-bottom:1px solid var(--dv);font:400 13px/1.3 var(--f);color:var(--c7);vertical-align:middle;white-space:nowrap}
tbody tr:hover td{background:var(--c1)}
tbody tr:last-child td{border-bottom:none}
/* Fixed left: checkbox + 姓名 */
.col-check{position:sticky;left:0;z-index:3;background:var(--sf);min-width:40px;width:40px}
thead th.col-check{background:var(--c1);z-index:4}
tbody tr:hover td.col-check{background:var(--c1)}
.col-name{position:sticky;left:40px;z-index:3;background:var(--sf);min-width:80px}
thead th.col-name{background:var(--c1);z-index:4}
tbody tr:hover td.col-name{background:var(--c1)}
/* Fixed right: 操作 */
.col-ops{position:sticky;right:0;z-index:3;background:var(--sf);min-width:120px}
thead th.col-ops{background:var(--c1);z-index:4}
tbody tr:hover td.col-ops{background:var(--c1)}
/* 异常原因 fixed width + ellipsis */
.col-reason{max-width:180px;min-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.table-checkbox{width:14px;height:14px;cursor:pointer;accent-color:var(--pr)}
.node-badge{display:inline-flex;align-items:center;gap:5px}
.node-num{width:22px;height:22px;border-radius:50%;border:1.5px solid var(--pr);color:var(--pr);font:600 12px/1 var(--f);display:flex;align-items:center;justify-content:center;flex-shrink:0;background:var(--pr50)}
.node-name{font:400 13px/1 var(--f);color:var(--c9)}
.ex-tag{display:inline-flex;font:500 12px/1 var(--f);padding:2px 10px;border-radius:4px;white-space:nowrap}
.ex-red{color:var(--ro700);background:var(--ro50)}
.ex-orange{color:var(--ac700);background:var(--ac50)}
.ex-dash{color:var(--c5)}
.grade{font:400 13px/1 var(--f);color:var(--c7)}
.grade.dash{color:var(--c5)}
.name-link{color:var(--c9);font-weight:500;cursor:pointer;text-decoration:none}
.name-link:hover{color:var(--pr)}

/* ═══ Row Ops ═══ */
.ops-cell{position:relative}
.ops-default{display:flex;align-items:center;gap:10px;white-space:nowrap}
.ops-default a{font:500 13px/1 var(--f);color:var(--c7);cursor:pointer;text-decoration:none;transition:color .15s}
.ops-default a:hover{color:var(--pr)}
.ops-expand-btn{font:500 13px/1 var(--f);color:var(--c5);cursor:pointer;background:none;border:none;font-family:var(--f);display:inline-flex;align-items:center;gap:3px;padding:0}
.ops-expand-btn:hover{color:var(--pr)}
.ops-expand-btn svg{width:12px;height:12px;transition:transform .2s}
.ops-expand-btn.open svg{transform:rotate(180deg)}
.ops-panel{position:absolute;top:100%;right:0;margin-top:4px;background:var(--sf);border:1px solid var(--c3);border-radius:var(--r1);box-shadow:0 6px 16px rgba(0,0,0,.08);padding:4px 0;z-index:50;min-width:110px;display:none}
.ops-panel.show{display:block}
.ops-panel-item{padding:7px 14px;font:400 13px/1 var(--f);color:var(--c7);cursor:pointer;transition:background .1s;white-space:nowrap}
.ops-panel-item:hover{background:var(--c1)}
.ops-panel-item.danger{color:var(--ro)}
.ops-panel-item.danger:hover{background:var(--ro50)}
.ops-panel-divider{height:1px;background:var(--dv);margin:3px 0}

/* ═══ Bottom Bar ═══ */
.bottom-bar{background:var(--sf);border:1px solid var(--c3);border-radius:var(--r2);box-shadow:var(--shadow);padding:12px 16px;display:flex;align-items:center;justify-content:space-between}
.bottom-left{display:flex;align-items:center;gap:12px}
.bottom-left .selected-info{display:flex;align-items:center;gap:8px;font:400 13px/1 var(--f);color:var(--c7)}
.bottom-left .selected-info .count{font-weight:600}
.clear-btn{font:500 13px/1 var(--f);color:var(--pr);cursor:pointer;background:none;border:none;font-family:var(--f)}
.clear-btn:hover{text-decoration:underline}
.bottom-right{display:flex;align-items:center;gap:16px}
.total-text{font:400 13px/1 var(--f);color:var(--c6)}
.pagination{display:flex;align-items:center;gap:4px}
.pg-btn{min-width:30px;height:30px;display:flex;align-items:center;justify-content:center;border-radius:var(--r1);font:500 13px/1 var(--f);color:var(--c7);cursor:pointer;border:1px solid var(--c3);background:var(--sf);transition:all .12s;font-family:var(--f)}
.pg-btn:hover{border-color:var(--pr);color:var(--pr)}
.pg-btn.active{background:var(--pr);color:#FFF;border-color:var(--pr)}
.pg-btn.disabled{color:var(--c5);cursor:not-allowed;border-color:var(--dv)}
.pg-btn.disabled:hover{border-color:var(--dv);color:var(--c5)}
.pg-ellipsis{min-width:30px;height:30px;display:flex;align-items:center;justify-content:center;font:400 13px/1 var(--f);color:var(--c5)}
.page-size-select{height:30px;padding:0 24px 0 8px;border:1px solid var(--c3);border-radius:var(--r1);font:400 13px/1 var(--f);color:var(--c7);background:var(--sf) url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%2394A3B8' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E") no-repeat right 6px center;appearance:none;cursor:pointer;outline:none;font-family:var(--f)}

/* ═══ Sub Page ═══ */
.sub-page-hd{display:flex;align-items:center;gap:12px;padding-bottom:16px;border-bottom:1px solid var(--dv);margin-bottom:20px}
.sub-page-hd .back{font:500 13px/1 var(--f);color:var(--pr);cursor:pointer;display:flex;align-items:center;gap:4px;background:none;border:none;font-family:var(--f)}
.sub-page-hd .back:hover{text-decoration:underline}
.sub-page-hd .title{font:600 16px/1.3 var(--f);color:var(--c9)}

/* Scheme Detail */
.scheme-section{background:var(--sf);border:1px solid var(--c3);border-radius:var(--r2);margin-bottom:16px;overflow:hidden;box-shadow:var(--shadow)}
.scheme-section-hd{display:flex;align-items:center;gap:8px;padding:14px 20px;border-bottom:1px solid var(--dv)}
.scheme-section-hd::before{content:'';width:3px;height:14px;background:var(--pr);border-radius:2px;flex-shrink:0}
.scheme-section-title{font:600 14px/1.3 var(--f);color:var(--c9)}
.scheme-section-bd{padding:16px 20px}
.scheme-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.scheme-item{display:flex;flex-direction:column;gap:4px}
.scheme-item .label{font:500 12px/1 var(--f);color:var(--c6)}
.scheme-item .value{font:400 13px/1.4 var(--f);color:var(--c9)}
.scheme-tags{display:flex;flex-wrap:wrap;gap:6px;margin-top:4px}
.scheme-tag{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:4px;font:500 12px/1 var(--f)}
.scheme-tag.grade-a{background:var(--ro50);color:var(--ro700)}
.scheme-tag.grade-bp{background:var(--ac50);color:var(--ac700)}
.scheme-tag.grade-b{background:var(--em50);color:var(--em700)}
.scheme-tag.grade-bm{background:var(--vi50);color:var(--vi)}
.scheme-tag.grade-c{background:var(--c2);color:var(--c6)}
.scheme-stage-list{display:flex;flex-direction:column;gap:8px}
.scheme-stage-item{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border:1px solid var(--dv);border-radius:var(--r1)}
.scheme-stage-name{font:500 13px/1 var(--f);color:var(--c9)}
.scheme-stage-desc{font:400 11px/1 var(--f);color:var(--c5);margin-top:2px}
.scheme-stage-tag{font:500 11px/1 var(--f);padding:2px 8px;border-radius:3px}
.scheme-stage-tag.on{background:var(--em50);color:var(--em700)}
.scheme-stage-tag.off{background:var(--c2);color:var(--c5)}
.scheme-group-list{display:flex;flex-direction:column;gap:8px}
.scheme-group-item{padding:12px 16px;border:1px solid var(--dv);border-radius:var(--r1)}
.scheme-group-name{font:600 13px/1 var(--f);color:var(--c9);display:flex;align-items:center;gap:8px}
.scheme-group-name .badge{font:500 10px/1 var(--f);padding:1px 6px;border-radius:3px;background:var(--pr50);color:var(--pr)}
.scheme-group-rules{font:400 12px/1 var(--f);color:var(--c6);margin-top:6px}

/* Op Log */
.oplog-table{width:100%;border-collapse:collapse}
.oplog-table th{font:600 13px/1 var(--f);color:var(--c6);text-align:left;padding:12px 14px;border-bottom:1px solid var(--dv);background:var(--c1)}
.oplog-table td{padding:12px 14px;border-bottom:1px solid var(--dv);font:400 13px/1.3 var(--f);color:var(--c7)}
.oplog-table tr:hover td{background:var(--c1)}
.oplog-type{display:inline-flex;font:500 12px/1 var(--f);padding:2px 10px;border-radius:4px}
.oplog-type.t-blue{background:var(--pr50);color:var(--pr)}
.oplog-type.t-green{background:var(--em50);color:var(--em700)}
.oplog-type.t-red{background:var(--ro50);color:var(--ro700)}
.oplog-type.t-orange{background:var(--ac50);color:var(--ac700)}
.oplog-type.t-purple{background:var(--vi50);color:var(--vi)}
.oplog-time{font:400 12px/1 var(--f);color:var(--c6);font-family:"SF Mono","JetBrains Mono",monospace;white-space:nowrap}

/* Detail Page */
.detail-card{background:var(--sf);border:1px solid var(--c3);border-radius:var(--r3);box-shadow:var(--shadow);padding:24px;max-width:1120px}
.detail-breadcrumb{font:400 13px/1 var(--f);color:var(--c6);margin-bottom:20px;display:flex;align-items:center;gap:8px}
.detail-breadcrumb .back{color:var(--pr);cursor:pointer;background:none;border:none;font:400 13px/1 var(--f);font-family:var(--f);display:inline-flex;align-items:center;gap:4px}
.detail-breadcrumb .back:hover{text-decoration:underline}
.detail-breadcrumb .sep{color:var(--c4)}
.detail-title-row{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px}
.detail-title-l{display:flex;flex-direction:column;gap:6px}
.detail-title-name{font:700 20px/1.3 var(--f);color:var(--c9);display:flex;align-items:center;gap:10px}
.detail-title-meta{font:400 13px/1 var(--f);color:var(--c6)}
.detail-title-meta .sep{margin:0 6px;color:var(--c4)}
.detail-title-r{display:flex;gap:8px;flex-shrink:0}
/* Flow Progress */
.detail-flow{display:flex;align-items:flex-start;position:relative;margin:28px 0 24px;padding:0 20px}
.detail-flow::before{content:'';position:absolute;top:18px;left:60px;right:60px;height:3px;background:var(--c3);z-index:0}
.detail-flow-stage{flex:1;display:flex;flex-direction:column;align-items:center;position:relative;z-index:1}
.detail-flow-dot{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font:600 13px/1 var(--f);margin-bottom:10px;border:3px solid var(--sf);transition:all .2s}
.detail-flow-dot.done{background:var(--em);color:#FFF}
.detail-flow-dot.active{background:var(--pr);color:#FFF;box-shadow:0 0 0 4px var(--pr50)}
.detail-flow-dot.pending{background:var(--c2);color:var(--c5)}
.detail-flow-name{font:600 13px/1 var(--f);color:var(--c9);margin-bottom:6px;text-align:center}
.detail-flow-status{font:500 12px/1 var(--f);padding:2px 8px;border-radius:4px;margin-bottom:4px}
.detail-flow-status.done{color:var(--em700);background:var(--em50)}
.detail-flow-status.active{color:var(--pr);background:var(--pr50)}
.detail-flow-status.pending{color:var(--c5);background:var(--c2)}
.detail-flow-date{font:400 12px/1 var(--f);color:var(--c5)}
.detail-flow-hint{font:400 11px/1 var(--f);color:var(--c5)}
/* Stage Tab */
.detail-stage-tab{display:inline-flex;font:600 14px/1 var(--f);color:var(--pr);padding-bottom:10px;border-bottom:2px solid var(--pr);margin-bottom:20px}
/* Node Table */
.detail-sec-title{font:600 15px/1.3 var(--f);color:var(--c9);margin-bottom:14px}
.detail-node-tbl{width:100%;border-collapse:collapse;margin-bottom:24px}
.detail-node-tbl th{background:var(--c1);font:600 13px/1 var(--f);color:var(--c6);text-align:left;padding:12px 16px;border-bottom:1px solid var(--dv)}
.detail-node-tbl td{padding:14px 16px;border-bottom:1px solid var(--dv);font:400 13px/1.3 var(--f);color:var(--c7);vertical-align:middle}
.detail-node-tbl tr:last-child td{border-bottom:none}
.detail-node-tbl tr:hover td{background:var(--c1)}
.detail-node-tbl .link{color:var(--pr);cursor:pointer;text-decoration:none;font:500 13px/1 var(--f)}
.detail-node-tbl .link:hover{text-decoration:underline}
.detail-node-tbl .dash{color:var(--c5)}
/* Stage Info Card */
.detail-info{border:1px solid var(--c3);border-radius:var(--r2);overflow:hidden}
.detail-info-row{display:flex;border-bottom:1px solid var(--dv)}
.detail-info-row:last-child{border-bottom:none}
.detail-info-label{width:100px;flex-shrink:0;padding:14px 16px;font:500 13px/1.4 var(--f);color:var(--c6);background:var(--c1);border-right:1px solid var(--dv)}
.detail-info-value{flex:1;padding:14px 16px;font:400 13px/1.4 var(--f);color:var(--c7);display:flex;align-items:center;gap:8px}
.detail-info-value .red{color:var(--ro);font-weight:500}
.detail-info-value .link{color:var(--pr);cursor:pointer;display:inline-flex;align-items:center;gap:4px}
.detail-info-value .link:hover{text-decoration:underline}
.detail-info-value .record-link{margin-left:auto;color:var(--pr);cursor:pointer;display:inline-flex;align-items:center;gap:4px;font:500 13px/1 var(--f)}
.detail-info-value .record-link:hover{text-decoration:underline}

.toast{position:fixed;top:20px;left:50%;transform:translateX(-50%);background:#1F2937;color:#FFF;padding:10px 20px;border-radius:8px;font:500 13px/1 var(--f);z-index:9999;opacity:0;transition:opacity .25s;pointer-events:none}
.toast.show{opacity:1}
</style>
</head>
<body>

<!-- Content -->
<div id="pageRoot"></div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script src="navigation.js"></script>
<script>
// ═══ State ═══
let subPage = null;
let detailIdx = null;
let selectedRows = new Set();
let expandedOps = new Set();
let currentPage = 1;

// ═══ Table Data ═══
const tableData = [
  { name:'张三', emp:'EMP001', dept:'技术部', node:2, nodeName:'绩效考核', handler:'李四', grade:'超出预期', approveGrade:'-', confirmStatus:'已确认', exception:'超时', exceptionCls:'ex-red', exceptionReason:'超过节点截止时间2天', updateTime:'2025-05-23 16:30', status:'进行中' },
